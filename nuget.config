<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="neillans" value="https://packages.neillans.co.uk/nuget/dotNet/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="neillans">
      <package pattern="aneillans.adapters-secrets.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
