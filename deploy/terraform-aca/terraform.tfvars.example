resource_group_name = "postyfox-rg"
location            = "uksouth"
image_registry      = "ghcr.io"
image_repository    = "your-org/postyfox"
image_tag           = "v1.0.0"

object_store_service_url = "https://<account>.blob.core.windows.net"
rabbitmq_host            = "my-rabbit.example.com"
otel_endpoint            = "http://otel-collector:4317"

# In-app OIDC bearer validation (the APIs are internal; the OIDC edge forwards the token).
auth_oidc_issuer   = "https://keycloak.example/realms/PostyFox"
auth_oidc_jwks_url = "https://keycloak.example/realms/PostyFox/protocol/openid-connect/certs"
auth_oidc_audience = "oauth2-proxy"

# Secret store (Neillans.Adapters.Secrets): AzureKeyVault | BitWarden | InMemory | Infisical.
# ACA defaults to Azure Key Vault — pairs naturally with the Container App's managed identity.
secrets_provider    = "AzureKeyVault"
azure_key_vault_uri = "https://my-vault.vault.azure.net/"
# Leave tenant/client empty to authenticate via the Container App's managed identity; set all three
# (incl. TF_VAR_azure_key_vault_client_secret) for service-principal auth instead.
# azure_key_vault_tenant_id = "<tenant-id>"
# azure_key_vault_client_id = "<client-id>"

# Secrets — supply via TF_VAR_* env vars in CI, not this file.
postgres_connection = "Host=...;Port=5432;Database=postyfox;Username=...;Password=..."
# BitWarden (only when secrets_provider = "BitWarden"): supply EITHER bitwarden_api_key OR the
# Organization API key pair.
# bitwarden_server_url    = "https://vault.example.com"
# bitwarden_api_key       = "<vaultwarden-access-token>"
# bitwarden_client_id     = "<org-client-id>"
# bitwarden_client_secret = "<org-client-secret>"
internal_token          = "<random>"
object_store_access_key = "..."
object_store_secret_key = "..."
rabbitmq_password       = "..."
