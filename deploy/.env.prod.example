# PostyFox PROD Environment Configuration
# Copy to /opt/postyfox/prod/.env and fill in the values
# This configuration uses strong security practices and external backing services

# GitHub Container Registry settings
IMAGE_REPOSITORY=ghcr.io/postyfox/postyfox-core
IMAGE_TAG=latest

# Database (CHANGE IN PRODUCTION!)
DB_PASSWORD=generate_strong_random_password_here_min_32_chars

# RabbitMQ (CHANGE IN PRODUCTION!)
RABBITMQ_USER=postyfox_prod
RABBITMQ_PASSWORD=generate_strong_random_password_here_min_32_chars

# --- Secret store (Neillans.Adapters.Secrets) ---
# Backend for connector/user/platform secrets: HashiCorpVault | BitWarden | AzureKeyVault | Infisical
# Production MUST use a persistent store — default is the bundled HashiCorp Vault (see the HashiCorp
# Vault section below for the AppRole credentials it needs).
SECRETS_PROVIDER=HashiCorpVault
BITWARDEN_SERVER_URL=https://vault.example.com
# Authenticate with EITHER a personal API/access token...
BITWARDEN_API_KEY=generate_from_bitwarden_vaultwarden
# ...OR an Organization API key (client credentials; mutually exclusive with the API key):
BITWARDEN_CLIENT_ID=
BITWARDEN_CLIENT_SECRET=
BITWARDEN_ORGANIZATION_ID=
BITWARDEN_IDENTITY_URL=
# AzureKeyVault / Infisical use the same Secrets__<Provider>__* env keys — see deploy/README.md.

# --- HashiCorp Vault (internal, auto-initialised + auto-unsealed) ---
# Vault image tag.
VAULT_VERSION=1.18
# Shamir seal parameters used on first init. NOTE: auto-unseal stores every generated key together
# on the `postyfox-prod-vault-keys` volume — back that volume up and restrict access; for a stronger
# posture switch Vault to a Transit / cloud-KMS seal and remove the vault-init sidecar.
VAULT_KEY_SHARES=5
VAULT_KEY_THRESHOLD=3
# App AppRole credentials. vault-init PINS the AppRole to these exact values and the app
# authenticates with them. Generate strong random values (e.g. `openssl rand -hex 24`) and keep them
# secret — anyone holding both can read the app's secrets from Vault.
VAULT_ROLE_ID=generate_strong_random_role_id
VAULT_SECRET_ID=generate_strong_random_secret_id
# KV v2 mount + path prefix the app's secrets live under (defaults shown).
VAULT_MOUNT=secret
VAULT_BASE_PATH=postyfox

# External RustFS (S3-compatible object storage)
# Should be on reliable, possibly replicated infrastructure
RUSTFS_HOST=rustfs.prod.internal
RUSTFS_PROTOCOL=https
RUSTFS_PORT=9000
RUSTFS_ACCESS_KEY=prod_access_key
RUSTFS_SECRET_KEY=prod_secret_key

# External Keycloak — in-cluster back channel (server-side token exchange + JWKS)
# Should be on reliable, possibly replicated infrastructure
KEYCLOAK_HOST=keycloak.prod.internal
KEYCLOAK_PORT=8080
KEYCLOAK_REALM=PostyFox
# Browser-facing Keycloak base URL (no trailing slash). MUST equal the token issuer (`iss`).
KEYCLOAK_PUBLIC_URL=https://auth.example.com

# Internal token for node connectors (CHANGE IN PRODUCTION!)
INTERNAL_TOKEN=generate_strong_random_token_min_32_chars

# --- OIDC edge (oauth2-proxy) — the only public entry point ---
# Public base URL where users reach the edge (used for the OAuth2 callback).
PUBLIC_BASE_URL=https://app.example.com
# Confidential client registered in the realm for oauth2-proxy.
OIDC_CLIENT_ID=oauth2-proxy
OIDC_CLIENT_SECRET=generate_from_keycloak_client_credentials
# Cookie secret — must be 16, 24, or 32 bytes: openssl rand -hex 16
OAUTH2_PROXY_COOKIE_SECRET=generate_with_openssl_rand_base64_32_piped_tr
# Host port the edge publishes; put your TLS terminator / load balancer in front of it.
EDGE_PORT=4180
# Keep true in production (TLS terminator in front). Only false for plain-HTTP exposure.
EDGE_COOKIE_SECURE=true


# OpenTelemetry. Apps export to the local edge collector; the collector shapes + forwards OTLP
# to the CENTRAL Data Prepper (traces 21890 / metrics 21891 / logs 21892), which writes to the
# shared OpenSearch cluster and owns the Observability-plugin schema, service maps, and secrets.
OTEL_ENDPOINT=http://otel-collector:4317
OTEL_CENTRAL_HOST=central-data-prepper
# Stamped onto every signal so you can filter by environment/cluster in OpenSearch.
DEPLOY_ENV=prod
DEPLOY_CLUSTER=postyfox
# nginx (gateway) access logs: fluent-bit → local collector → Data Prepper (:21893) →
# ss4o_logs-nginx-<env>. No OpenSearch creds needed on this host.

# Optional: Sentry or other error tracking
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Optional: Additional prod hardening
# ASPNETCORE_ENVIRONMENT=Production

# Tumblr Config
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=

