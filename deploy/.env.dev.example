# PostyFox DEV Environment Configuration
# Copy to /opt/postyfox/dev/.env and fill in the values

# GitHub Container Registry settings
IMAGE_REPOSITORY=ghcr.io/postyfox/postyfox-core
IMAGE_TAG=latest

# Database
DB_PASSWORD=change_me_dev_password_123

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- Secret store (Neillans.Adapters.Secrets) ---
# Backend for connector/user/platform secrets: HashiCorpVault | InMemory | BitWarden | AzureKeyVault | Infisical
# Dev defaults to the bundled HashiCorp Vault (see the HashiCorp Vault section below for the AppRole
# credentials it needs). Set SECRETS_PROVIDER=InMemory for an ephemeral store (secrets lost on restart).
SECRETS_PROVIDER=HashiCorpVault
# BitWarden / VaultWarden — used when SECRETS_PROVIDER=BitWarden.
BITWARDEN_SERVER_URL=https://vault.example.com
# Authenticate with EITHER a personal API/access token...
BITWARDEN_API_KEY=
# ...OR an Organization API key (client credentials; mutually exclusive with the API key):
BITWARDEN_CLIENT_ID=
BITWARDEN_CLIENT_SECRET=
BITWARDEN_ORGANIZATION_ID=
BITWARDEN_IDENTITY_URL=
# AzureKeyVault / Infisical use the same Secrets__<Provider>__* env keys — see deploy/README.md.

# --- HashiCorp Vault (internal, auto-initialised + auto-unsealed) ---
# Vault image tag.
VAULT_VERSION=1.18
# Shamir seal parameters used on first init. All generated keys are stored together on the
# `postyfox-dev-vault-keys` volume and re-applied automatically on every start.
VAULT_KEY_SHARES=5
VAULT_KEY_THRESHOLD=3
# App AppRole credentials. vault-init PINS the AppRole to these exact values and the app
# authenticates with them — so they just need to match on both sides. For dev they can be any
# fixed strings; generate strong random values for anything real (e.g. `openssl rand -hex 24`).
VAULT_ROLE_ID=postyfox-dev-role
VAULT_SECRET_ID=change-me-dev-secret-id
# KV v2 mount + path prefix the app's secrets live under (defaults shown).
VAULT_MOUNT=secret
VAULT_BASE_PATH=postyfox

# External RustFS (S3-compatible object storage)
RUSTFS_HOST=rustfs.example.com
RUSTFS_PORT=9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin

# External Keycloak — in-cluster back channel (server-side token exchange + JWKS)
KEYCLOAK_HOST=keycloak.example.com
KEYCLOAK_PORT=8080
KEYCLOAK_REALM=PostyFox
# Browser-facing Keycloak base URL (no trailing slash). MUST equal the token issuer (`iss`).
KEYCLOAK_PUBLIC_URL=https://auth.dev.example.com

# Internal token for node connectors
INTERNAL_TOKEN=postyfox-internal-dev-token

# --- OIDC edge (oauth2-proxy) — the only public entry point ---
# Public base URL where users reach the edge (used for the OAuth2 callback).
PUBLIC_BASE_URL=https://app.dev.example.com
# Confidential client registered in the realm for oauth2-proxy.
OIDC_CLIENT_ID=oauth2-proxy
OIDC_CLIENT_SECRET=oauth2-proxy-secret
# Cookie secret — must be 16, 24, or 32 bytes: openssl rand -hex 16
OAUTH2_PROXY_COOKIE_SECRET=0123456789abcdef0123456789abcdef
# Host port the edge publishes (front it with your TLS terminator).
EDGE_PORT=4180
# Set to false only if the edge is exposed over plain HTTP (no TLS terminator in front).
EDGE_COOKIE_SECURE=true

# OpenTelemetry. Apps export to the local edge collector; the collector shapes + forwards OTLP
# to the CENTRAL Data Prepper (traces 21890 / metrics 21891 / logs 21892), which writes to the
# shared OpenSearch cluster and owns the Observability-plugin schema, service maps, and secrets.
OTEL_ENDPOINT=http://otel-collector:4317
OTEL_CENTRAL_HOST=central-data-prepper
# Stamped onto every signal so you can filter by environment/cluster in OpenSearch.
DEPLOY_ENV=dev
DEPLOY_CLUSTER=postyfox

# Tumblr Config
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=
